    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^25.9.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^24.1.0",
